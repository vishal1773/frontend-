generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CITIZEN
  SHOPKEEPER
  DISTRICT_OFFICER
  STATE_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum ComplaintStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum StockMovementType {
  RECEIPT
  ISSUE
  ADJUSTMENT
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  OFFLINE
}

model District {
  id String @id @default(cuid())
  name String @unique
  code String @unique
  users User[]
  shops Shop[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id String @id @default(cuid())
  fullName String
  mobileNumber String @unique
  email String? @unique
  passwordHash String?
  role Role
  status UserStatus @default(ACTIVE)
  districtId String?
  district District? @relation(fields: [districtId], references: [id])
  rationCard RationCard?
  managedShop Shop? @relation("Shopkeeper")
  complaints Complaint[] @relation("CitizenComplaints")
  notifications Notification[]
  refreshTokens RefreshToken[]
  otpCodes OtpCode[]
  chats ChatMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([role, districtId])
}

model Shop {
  id String @id @default(cuid())
  code String @unique
  name String
  address String
  districtId String
  district District @relation(fields: [districtId], references: [id])
  shopkeeperId String? @unique
  shopkeeper User? @relation("Shopkeeper", fields: [shopkeeperId], references: [id])
  inventory Inventory[]
  transactions RationTransaction[]
  devices Device[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RationCard {
  id String @id @default(cuid())
  cardNumber String @unique
  aadhaarLast4 String
  address String
  familySize Int @default(1)
  citizenId String @unique
  citizen User @relation(fields: [citizenId], references: [id])
  quotas MonthlyQuota[]
  transactions RationTransaction[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Commodity {
  id String @id @default(cuid())
  code String @unique
  name String @unique
  unit String
  inventories Inventory[]
  quotaItems QuotaItem[]
  transactionItems TransactionItem[]
}

model MonthlyQuota {
  id String @id @default(cuid())
  rationCardId String
  rationCard RationCard @relation(fields: [rationCardId], references: [id], onDelete: Cascade)
  month DateTime @db.Date
  items QuotaItem[]
  @@unique([rationCardId, month])
}

model QuotaItem {
  id String @id @default(cuid())
  quotaId String
  quota MonthlyQuota @relation(fields: [quotaId], references: [id], onDelete: Cascade)
  commodityId String
  commodity Commodity @relation(fields: [commodityId], references: [id])
  allocated Decimal @db.Decimal(10, 2)
  collected Decimal @default(0) @db.Decimal(10, 2)
  @@unique([quotaId, commodityId])
}

model Inventory {
  id String @id @default(cuid())
  shopId String
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  commodityId String
  commodity Commodity @relation(fields: [commodityId], references: [id])
  quantity Decimal @db.Decimal(12, 2)
  reorderLevel Decimal @db.Decimal(12, 2)
  movements StockMovement[]
  @@unique([shopId, commodityId])
}

model StockMovement {
  id String @id @default(cuid())
  inventoryId String
  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  type StockMovementType
  quantity Decimal @db.Decimal(12, 2)
  reference String?
  createdAt DateTime @default(now())
}

model RationTransaction {
  id String @id @default(cuid())
  receiptNumber String @unique
  shopId String
  shop Shop @relation(fields: [shopId], references: [id])
  rationCardId String
  rationCard RationCard @relation(fields: [rationCardId], references: [id])
  items TransactionItem[]
  issuedAt DateTime @default(now())
}

model TransactionItem {
  id String @id @default(cuid())
  transactionId String
  transaction RationTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  commodityId String
  commodity Commodity @relation(fields: [commodityId], references: [id])
  quantity Decimal @db.Decimal(10, 2)
}

model Complaint {
  id String @id @default(cuid())
  reference String @unique
  citizenId String
  citizen User @relation("CitizenComplaints", fields: [citizenId], references: [id])
  category String
  title String
  description String
  status ComplaintStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id String @id @default(cuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  title String
  body String
  readAt DateTime?
  createdAt DateTime @default(now())
}

model OtpCode {
  id String @id @default(cuid())
  userId String?
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  mobileNumber String
  codeHash String
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())
  @@index([mobileNumber, expiresAt])
}

model RefreshToken {
  id String @id @default(cuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
}

model Device {
  id String @id @default(cuid())
  deviceId String @unique
  shopId String
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  status DeviceStatus @default(ACTIVE)
  lastSeenAt DateTime?
  readings SensorReading[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SensorReading {
  id String @id @default(cuid())
  deviceId String
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  metric String
  value Decimal @db.Decimal(14, 4)
  recordedAt DateTime @default(now())
  @@index([deviceId, recordedAt])
}

model ChatMessage {
  id String @id @default(cuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role String
  content String
  createdAt DateTime @default(now())
}
